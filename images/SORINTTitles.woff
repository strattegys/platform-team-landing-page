<script>
function condividiSuFacebook() {
  var permalink = window.location.href; // Ottiene il permalink della pagina corrente

  // Stampa il codice HTML per il link di condivisione su Facebook
  document.write('<a href="https://www.facebook.com/sharer/sharer.php?u=' + encodeURIComponent(permalink) + '" target="_blank">');
  document.write('<img width="40px" src="https://3.76.6.79/wp-content/uploads/2023/06/facebook-2.svg" alt="Condividi su Facebook">');
  document.write('</a>');
}
</script>

<script>
function condividiSuLinkedIn() {
  var permalink = window.location.href; // Ottiene il permalink della pagina corrente

  // Stampa il codice HTML per il link di condivisione su LinkedIn
  document.write('<a href="https://www.linkedin.com/sharing/share-offsite/?url=' + encodeURIComponent(permalink) + '" target="_blank">');
  document.write('<img width="40px" src="https://3.76.6.79/wp-content/uploads/2023/06/linkedin.svg" alt="Condividi su LinkedIn">');
  document.write('</a>');
}
</script>

<script>
function condividiSuTwitter() {
  var permalink = window.location.href; // Ottiene il permalink della pagina corrente
  var title = document.title; // Ottiene il titolo della pagina corrente

  // Stampa il codice HTML per il link di condivisione su Twitter
  document.write('<a href="https://twitter.com/intent/tweet?url=' + encodeURIComponent(permalink) + '&text=' + encodeURIComponent(title) + '" target="_blank">');
  document.write('<img width="40px" src="https://3.76.6.79/wp-content/uploads/2023/06/twitter.svg" alt="Condividi su Twitter">');
  document.write('</a>');
}
</script>


